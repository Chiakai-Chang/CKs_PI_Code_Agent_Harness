{
  "providers": {
    "ollama-local": {
      "baseUrl": "http://localhost:11434",
      "api": "openai-completions",
      "apiKey": "local",
      "authHeader": true,
      "compat": {
        "supportsDeveloperRole": false,
        "maxTokensField": "max_tokens"
      },
      "models": [
        {
          "id": "llama3.2",
          "name": "llama3.2",
          "reasoning": false,
          "contextWindow": 8192,
          "maxTokens": 4096,
          "input": ["text"],
          "cost": {
            "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0
          }
        }
      ]
    }
  }
}
